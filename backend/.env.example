# ---- database ----
# dev (zero setup): SQLite file. prod (Render): postgresql://USER:PASS@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./altspace.db

# ---- auth (JWT) ----
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- LLM: Groq free tier — get a key at https://console.groq.com ----
GROQ_API_KEY=gsk_replace_me
CLASSIFIER_MODEL=llama-3.1-8b-instant
SUMMARY_MODEL=llama-3.3-70b-versatile

# ---- CORS: where the Streamlit frontend is served from ----
FRONTEND_ORIGIN=http://localhost:8501
